# React Native Production .gitignore

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# Node / JavaScript
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json.bak
yarn.lock.bak

# Logs
logs
*.log

# Coverage / Testing
coverage/
.nyc_output/
jest-results.json

# Metro / React Native
.metro-health-check*
.expo/
.expo-shared/

# Environment Files
.env
.env.*
!.env.example

# IDE / Editors
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.iml

# React Native / Build Outputs

# Common
build/
dist/
tmp/
temp/

# Android
android/.gradle/
android/app/build/
android/build/
android/local.properties
android/.idea/
android/*.iml
android/.cxx/
android/captures/
android/app/debug/
android/app/release/
android/app/profile/
android/app/*.keystore
android/*.keystore
!android/app/debug.keystore

# Kotlin
.kotlin/

# Native crash logs
*.hprof

# iOS
ios/build/
ios/Pods/
ios/.symlinks/
ios/DerivedData/
ios/*.xcworkspace
!ios/*.xcworkspace/contents.xcworkspacedata
ios/xcuserdata/
ios/*.xcodeproj/xcuserdata/
ios/**/*.xcuserstate
ios/**/*.xcode.env.local

# Xcode temp files
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
*.moved-aside

# Bundle output
*.jsbundle

# Ruby / CocoaPods / Fastlane
vendor/bundle/

fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/
fastlane/test_output/

# TypeScript
*.tsbuildinfo

# Cache Files
.cache/
.parcel-cache/
.eslintcache
.prettiercache
babel.config.js.cache

# Secrets / Certificates / Keys
*.p12
*.pem
*.key
*.mobileprovision

# Misc
*.swp
*.swo
*.orig
*.rej

# Keep Important Files
!README.md
!LICENSE